{
  "kind": "collectionType",
  "collectionName": "experts",
  "info": {
    "singularName": "expert",
    "pluralName": "experts",
    "displayName": "Expert"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "specialty": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "text"
    },
    "bio_long": {
      "type": "text"
    },
    "expertise": {
      "type": "json"
    },
    "experience": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "credentials": {
      "type": "json"
    },
    "certifications": {
      "type": "json"
    },
    "consultationAvailable": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "consultationFee": {
      "type": "decimal"
    },
    "Duration": {
      "type": "integer",
      "required": true,
      "default": 1
    },
    "availability": {
      "type": "json"
    },
    "languages": {
      "type": "json"
    },
    "verified": {
      "type": "boolean"
    },
    "verificationDocument": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "profileBanner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "mappedBy": "expert"
    },
    "consultations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::consultation.consultation",
      "mappedBy": "expert"
    },
    "review_and_ratings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review-and-rating.review-and-rating",
      "mappedBy": "expert"
    }
  }
}
